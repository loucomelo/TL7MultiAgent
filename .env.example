# Copy this file to .env.local for local development.
# In Vercel, set these under Project Settings → Environment Variables instead.

# Required — your Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional but recommended for production — without these, the learnings
# review queue resets on every serverless cold start (fine for testing,
# NOT fine for a real deployment). Create a KV store in the Vercel dashboard
# under Storage → KV, and it will auto-populate these for you.
KV_REST_API_URL=
KV_REST_API_TOKEN=
